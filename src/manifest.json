{
  "package": "com.example.photo-viewer",
  "name": "photo-viewer",
  "icon": "/common/icon.png",
  "versionName": "1.0",
  "versionCode": 1,
  "minPlatformVersion": 1100,
  "simulationVersion": "default",
  "deviceTypeList": ["watch"],
  "features": [
    { "name": "system.file" },
    { "name": "system.router" },
    { "name": "system.fetch" }
  ],
  "config": {
    "logLevel": "log",
    "designWidth": 432
  },
  "router": {
    "entry": "pages/index",
    "pages": {
      "pages/index": {
        "component": "index"
      },
      "pages/copy": {
        "component": "copy"
      }
    }
  },
  "display": {
    "backgroundColor": "#ffffff"
  }
}
